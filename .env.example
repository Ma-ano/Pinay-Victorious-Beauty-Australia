# ============================================
# Pinay Victorious Beauty — Environment Variables
# Copy this file to .env.local and fill in values
# ============================================

# Maintenance Mode — set to "true" to show maintenance page on all routes
MAINTENANCE_MODE=false

# Site URL (production URL when deploying)
SITE_URL=http://localhost:3000/

# --- Firebase Client (public, exposed to browser) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- SMTP (Gmail App Password) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Pinay Victorious Beauty" <hello@pinayvictorious.com>

# --- Admin ---
# The email address that will be promoted to admin via the setup endpoint
ADMIN_EMAIL=your-email@gmail.com
# A secret key required to authorize the admin setup endpoint
ADMIN_SETUP_SECRET=generate-a-random-secret-here

# --- PayPal (optional — enables PayPal payments in checkout) ---
# Get credentials from https://developer.paypal.com/dashboard → Apps & Credentials
# For sandbox testing: use a sandbox app's Client ID + Secret, and set PAYPAL_USE_SANDBOX=true
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Set to "true" to use PayPal sandbox (for testing). Remove or set to "false" for live payments.
PAYPAL_USE_SANDBOX=true

# --- Afterpay (optional — enables Afterpay in checkout) ---
# Get credentials from https://portal.afterpay.com/
# For sandbox testing: use sandbox credentials and set AFTERPAY_USE_SANDBOX=true
NEXT_PUBLIC_AFTERPAY_MERCHANT_ID=
AFTERPAY_SECRET_KEY=
AFTERPAY_USE_SANDBOX=true

# --- Firebase Admin SDK (server-side only — NEVER exposed to browser) ---
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# IMPORTANT: The private key must use \n for newlines (not actual line breaks)
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
